# Network
I8SL_SERVICE_NAME=I8SL
I8SL_ENV=development
I8SL_HTTP_ADDR=:8080
I8SL_BASE_URL=http://localhost:8080
I8SL_LOG_LEVEL=info

# Storage
I8SL_STORAGE_DRIVER=sqlite
I8SL_SQLITE_PATH=./i8sl.db

# PostgreSQL runtime example
# I8SL_STORAGE_DRIVER=postgres
I8SL_DB_URI=postgres://i8sl:i8sl@localhost:5432/i8sl?sslmode=disable

# Rate limiting backend
I8SL_RATE_LIMIT_BACKEND=memory
# I8SL_RATE_LIMIT_BACKEND=redis
I8SL_REDIS_ADDR=localhost:6379
I8SL_REDIS_PASSWORD=
I8SL_REDIS_DB=0
I8SL_REDIS_KEY_PREFIX=i8sl:rate_limit

# Short codes
I8SL_CODE_LENGTH=7

# Rate limits
I8SL_GENERATION_RATE_PER_MINUTE=30
I8SL_GENERATION_BURST=10

# Admin/API security
# I8SL_ADMIN_TOKEN=change-me
I8SL_REJECT_PRIVATE_TARGETS=false

# Reverse proxy settings
# I8SL_TRUSTED_PROXIES=127.0.0.1/32,10.0.0.0/8

# Maintenance and observability
I8SL_CLEANUP_INTERVAL=30m
I8SL_METRICS_PATH=/metrics

# Tracing
I8SL_TRACING_ENABLED=false
I8SL_OTLP_ENDPOINT=localhost:4318
I8SL_OTLP_INSECURE=true
I8SL_TRACE_SAMPLE_RATIO=1
