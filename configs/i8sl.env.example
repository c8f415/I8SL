# Network
I8SL_HTTP_ADDR=:8080
I8SL_BASE_URL=http://localhost:8080

# Storage
I8SL_STORAGE_DRIVER=sqlite
I8SL_SQLITE_PATH=./i8sl.db

# PostgreSQL runtime example
# I8SL_STORAGE_DRIVER=postgres
I8SL_DB_URI=postgres://i8sl:i8sl@localhost:5432/i8sl?sslmode=disable

# Short codes
I8SL_CODE_LENGTH=7

# Rate limits
I8SL_GENERATION_RATE_PER_MINUTE=30
I8SL_GENERATION_BURST=10
